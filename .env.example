# File source: smb | local | both (both shows /files/smb and /files/local as roots)
FILE_SOURCE=smb
# When FILE_SOURCE is local or both, path to local embroidery files (e.g. mounted volume)
LOCAL_MOUNT_PATH=/mnt/embroidery

# Samba Configuration (used when FILE_SOURCE is smb or both)
SMB_HOST=smb
SMB_SHARE=embroidery
SMB_USERNAME=embroidery
SMB_PASSWORD=your-password
SMB_PORT=445

# App Configuration
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=false
